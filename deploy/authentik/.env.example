# Authentik configuration for the openclaw cluster.
# Real values live in deploy/authentik/.env (gitignored) and are generated
# on first run by provision.sh — do not commit secrets here.

# --- Postgres (used by Authentik only) ---
PG_DB=authentik
PG_USER=authentik
PG_PASS=

# --- Authentik core ---
# 64+ hex chars. Changing this invalidates all active sessions.
AUTHENTIK_SECRET_KEY=

# Initial akadmin password (only used on first DB setup).
AUTHENTIK_BOOTSTRAP_PASSWORD=

# Initial API token for akadmin — provisioner uses this to create OIDC apps.
# Kept on disk in this file at 0600.
AUTHENTIK_BOOTSTRAP_TOKEN=

AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@localhost

# Image pin (override only when bumping Authentik versions).
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.2.3

# Host port to publish Authentik on (default 9000/9443). Override to expose
# on LAN by changing the address half (e.g. 0.0.0.0:9000).
HOST_BIND_HTTP=127.0.0.1:9000
HOST_BIND_HTTPS=127.0.0.1:9443

# Host port for the Authentik (+ paperclip) Postgres. Avoids clashing with
# any other local PG on 5432.
PG_HOST_PORT=5436

# Bridge subnet for the Authentik network. Pick a /16 that's not already in
# use by another Docker project AND not transparently intercepted by host
# nftables hooks. 172.20.0.0/16 is a common safe default.
AUTHENTIK_BRIDGE_SUBNET=172.20.0.0/16

# Set to 1 to skip bridge networking entirely and run all containers on
# host net. Use when bridge mode breaks (sing-box / Mullvad / split-tunnel
# tooling typically does this) or when 172.x ranges are all taken.
# AUTHENTIK_HOST_NET=1
